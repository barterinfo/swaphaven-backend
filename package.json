{
  "name": "swaphaven-api",
  "version": "1.0.0",
  "description": "SwapHaven — peer-to-peer item trading platform API (Express 5 + PostgreSQL + Drizzle ORM)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "sh -c 'node dist/db/migrate.js && exec node dist/index.js'",
    "migrate:prod": "node dist/db/migrate.js",
    "docker:build": "docker build -t swaphaven-api:latest .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "seed:listings": "tsx scripts/seed-listings.ts",
    "seed:user": "tsx scripts/seed-user.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "harness:validate": "harness validate",
    "harness:apply": "harness apply",
    "harness:check": "npm run harness:validate && npm run harness:apply && node -e \"const i=require('./.harness/managed-index.json');const {execSync}=require('child_process');const p=(i.managedOutputPaths||[]).join(' ');if(p)execSync('git diff --exit-code -- '+p,{stdio:'inherit'})\""
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1068.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.41.0",
    "express": "^5.0.0",
    "express-rate-limit": "^7.4.1",
    "firebase-admin": "^14.0.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "obscenity": "^0.4.6",
    "pg": "^8.13.0",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@madebywild/agent-harness-framework": "^1.10.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^4.1.6",
    "drizzle-kit": "^0.31.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6"
  }
}
