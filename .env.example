# ─── Database ──────────────────────────────────────────────────────────────────
# SwapHaven has its own database — do NOT reuse the barter-stack DB.
DATABASE_URL=postgresql://user:password@localhost:5432/swaphaven

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * only for development.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per window per IP for auth routes
AUTH_RATE_LIMIT_MAX=20
# Max requests per window per IP for general API routes
API_RATE_LIMIT_MAX=300
# Window duration in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
