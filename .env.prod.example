# Production ads CLI — copy to .env.prod and set Railway DATABASE_URL.
#
#   cp .env.prod.example .env.prod
#   # Paste DATABASE_URL from Railway → Postgres service → Connect → Public URL
#   npm run ads:prod
#
# S3 vars can match local .env (same swaphaven-media-prod bucket). JWT secrets
# only satisfy env validation for the CLI — they need not match Railway.

# Full URL from Railway → Postgres → Connect (NOT host:port alone).
DATABASE_URL=postgresql://postgres:PASSWORD@kodama.proxy.rlwy.net:58402/railway

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_MEDIA_BUCKET=swaphaven-media-prod
